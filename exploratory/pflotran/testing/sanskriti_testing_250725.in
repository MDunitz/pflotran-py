#Description: 3D subsurface biogeochemistry with atmospheric exchange on all boundaries
# Rate constants estimated to show different processes

SIMULATION
  SIMULATION_TYPE SUBSURFACE
  PROCESS_MODELS
    SUBSURFACE_FLOW flow
      MODE GENERAL
      OPTIONS
        ARITHMETIC_GAS_DIFFUSIVE_DENSITY
        ISOTHERMAL
        REPLACE_INIT_PARAMS_ON_RESTART
      /
    /    
    SUBSURFACE_TRANSPORT
      MODE GIRT
    /
  /
END

SUBSURFACE

#=========================== useful transport parameters =======================
REFERENCE_LIQUID_DENSITY 1.d3

#=========================== chemistry ========================================
CHEMISTRY
PRIMARY_SPECIES
  DOM1
  H+
  O2(aq)
  HCO3-
  Fe+++
  Fe++
  NH4+
  Tracer
  Tracer2
  Tracer3
  CH4(aq)
  Acetate-
  H2(aq)
  Mg++
  Ca++
  Na+
  K+
  Cl-
/
DECOUPLED_EQUILIBRIUM_REACTIONS
  DOM1
  H+
  O2(aq)
  HCO3-
  Fe+++
  Fe++
  NH4+
  Tracer
  Tracer2
  Tracer3
  CH4(aq)
  Acetate-
  H2(aq)
  Mg++
  Ca++
  Na+
  K+
  Cl-
/
SECONDARY_SPECIES
  CO2(aq)
  OH-
  FeCO3+
  Fe(OH)4-
  Acetic_acid(aq)
  FeCH3COO+
  Fe(OH)2(aq)
  FeCO3(aq)
  CO3--
  CaHCO3+
/
MINERALS
  Fe(OH)3
  Fe(OH)2
  Rock(s)
/
MINERAL_KINETICS
  Fe(OH)3
    RATE_CONSTANT  1.d-6 mol/m^2-sec
  /
  Fe(OH)2
    RATE_CONSTANT  1.d-7 mol/m^2-sec
  /
  Rock(s)
    RATE_CONSTANT  0.0 mol/m^2-sec
  /
/
IMMOBILE_SPECIES
  cellulose
  HRimm
/
PASSIVE_GAS_SPECIES
  CO2(g)
  O2(g)
/
SORPTION
  ION_EXCHANGE_RXN
    MINERAL Rock(s)
    CEC 2.00e+03
    CATIONS
      Fe++ 1.00d-01
      Fe+++ 3.00d-01
      Mg++ 1.10e+00
      Ca++ 4.10e+00
      Na+ 1.00e+00 REFERENCE
      K+ 9.00d-01
      H+ 1.10e+00
    /
  /
/

  # Enhanced fermentation (higher rate for biomass)
  MICROBIAL_REACTION
    REACTION 1.00e+00 DOM1  + 6.67e-01 H2O  -> 3.33e-01 Acetate-  + 3.33e-01 HCO3-  + 6.67e-01 H+  + 6.67e-01 H2(aq)  + 3.33e-01 Tracer 
    RATE_CONSTANT       3.00e-07   # 5x higher rate
    MONOD
      SPECIES_NAME        DOM1
      HALF_SATURATION_CONSTANT 5.00e-02  # Lower Km for easier breakdown
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    INHIBITION
      SPECIES_NAME        O2(aq)
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-05
      INHIBIT_ABOVE_THRESHOLD
    /
    INHIBITION
      SPECIES_NAME        Acetate-
      TYPE MONOD
      THRESHOLD_CONCENTRATION 4.00e-02
      INHIBIT_ABOVE_THRESHOLD
    /
  /
  
  # DOM aerobic respiration
  MICROBIAL_REACTION
    REACTION 1.00e+00 DOM1  + 1.00e+00 O2(aq)  + 1.00e+00 H2O  -> 1.00e+00 HCO3-  + 1.00e+00 H+  + 1.00e+00 Tracer 
    RATE_CONSTANT       1.80e-07
    MONOD
      SPECIES_NAME        O2(aq)
      HALF_SATURATION_CONSTANT 1.00e-04
      THRESHOLD_CONCENTRATION 0.00e+00
    /
    MONOD
      SPECIES_NAME        DOM1
      HALF_SATURATION_CONSTANT 1.00e-01
      THRESHOLD_CONCENTRATION 1.10e-16
    /
  /

  # Fe(II) abiotic oxidation
  GENERAL_REACTION
    REACTION 1.00e+00 Fe++  + 2.50e-01 O2(aq)  + 1.00e+00 H+  <-> 1.00e+00 Fe+++  + 5.00e-01 H2O + 1.00e+00 Tracer3
    FORWARD_RATE        1.00e-2
    BACKWARD_RATE       0.00e-06
  /
  
  # Fe(II) microbial oxidation
  MICROBIAL_REACTION
    REACTION 1.00e+00 Fe++  + 2.50e-01 O2(aq)  + 1.00e+00 H+  -> 1.00e+00 Fe+++  + 5.00e-01 H2O 
    RATE_CONSTANT    5.5e-05
    MONOD
      SPECIES_NAME        O2(aq)
      HALF_SATURATION_CONSTANT 1.00e-08
      THRESHOLD_CONCENTRATION 0.00e+00
    /
    MONOD
      SPECIES_NAME        Fe++
      HALF_SATURATION_CONSTANT 1.00e-04
      THRESHOLD_CONCENTRATION 1.10e-15
    /
  /

  # Hydrogenotrophic methanogenesis with salt inhibition
  MICROBIAL_REACTION
    REACTION 4.00e+00 H2(aq)  + 1.00e+00 HCO3-  + 1.00e+00 H+  -> 1.00e+00 CH4(aq)  + 2.00e+00 H2O 
    RATE_CONSTANT       7.2e-09
    MONOD
      SPECIES_NAME        H2(aq)
      HALF_SATURATION_CONSTANT 1.00e-01
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    MONOD
      SPECIES_NAME        HCO3-
      HALF_SATURATION_CONSTANT 1.00e-01
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    INHIBITION
      SPECIES_NAME        O2(aq)
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-05
      INHIBIT_ABOVE_THRESHOLD
    /
    INHIBITION
      SPECIES_NAME        Fe+++
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-10
      INHIBIT_ABOVE_THRESHOLD
    /
    # Salt inhibition: 20% NaCl by weight ≈ 3.4 M total salt
    INHIBITION
      SPECIES_NAME        Na+
      TYPE MONOD
      THRESHOLD_CONCENTRATION 3.4d0    # ~20% salt by weight
      INHIBIT_ABOVE_THRESHOLD
    /
  /

  # Acetoclastic methanogenesis with salt inhibition
  MICROBIAL_REACTION
    REACTION 1.00e+00 Acetate-  + 1.00e+00 H2O  -> 1.00e+00 CH4(aq)  + 1.00e+00 HCO3-
    RATE_CONSTANT       1.5e-8
    MONOD
      SPECIES_NAME        Acetate-
      HALF_SATURATION_CONSTANT 4.00e-02
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    INHIBITION
      SPECIES_NAME        O2(aq)
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-5
      INHIBIT_ABOVE_THRESHOLD
    /
    INHIBITION
      SPECIES_NAME        Fe+++
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-10
      INHIBIT_ABOVE_THRESHOLD
    /
    INHIBITION
      SPECIES_NAME        H+
      TYPE MONOD
      THRESHOLD_CONCENTRATION 2.88e-06
      INHIBIT_ABOVE_THRESHOLD
    /
    # Salt inhibition: 20% NaCl by weight ≈ 3.4 M total salt
    INHIBITION
      SPECIES_NAME        Na+
      TYPE MONOD
      THRESHOLD_CONCENTRATION 3.4d0    # ~20% salt by weight
      INHIBIT_ABOVE_THRESHOLD
    /
  /

  # Hydrogen oxidation
  MICROBIAL_REACTION
    REACTION 2.00e+00 H2(aq)  + 1.00e+00 O2(aq)  -> 2.00e+00 H2O 
    RATE_CONSTANT       1.5e-06
    MONOD
      SPECIES_NAME        H2(aq)
      HALF_SATURATION_CONSTANT 1.00e-01
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    MONOD
      SPECIES_NAME        O2(aq)
      HALF_SATURATION_CONSTANT 1.00e-04
      THRESHOLD_CONCENTRATION 0.00e+00
    /
  /

  # Fe(III) reduction
  MICROBIAL_REACTION
    REACTION 1.00e+00 Acetate-  + 8.00e+00 Fe+++  + 4.00e+00 H2O  -> 2.00e+00 HCO3-  + 8.00e+00 Fe++  + 9.00e+00 H+  + 2.00e+00 Tracer 
    RATE_CONSTANT       2.25e-08
    MONOD
      SPECIES_NAME        Acetate-
      HALF_SATURATION_CONSTANT 4.00e-2
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    MONOD
      SPECIES_NAME        Fe+++
      HALF_SATURATION_CONSTANT 1.00e-10
      THRESHOLD_CONCENTRATION 1.10e-15
    /
    INHIBITION
      SPECIES_NAME        O2(aq)
      TYPE MONOD
      THRESHOLD_CONCENTRATION 1.00e-05
      INHIBIT_ABOVE_THRESHOLD
    /
  /

  # Ebullition
  MICROBIAL_REACTION
    REACTION 1.00e+00 CH4(aq) -> 1.00e+00 Tracer2
    RATE_CONSTANT       3.00e-08
    MONOD
      SPECIES_NAME        CH4(aq)
      HALF_SATURATION_CONSTANT 4.00e-02
      THRESHOLD_CONCENTRATION 2.5e-3  # Only occurs above threshold concentration
    /
  /

  LOG_FORMULATION
  TRUNCATE_CONCENTRATION 1.00d-25
  DATABASE /home/sshindad/miniconda/pflotran/md_test_files/hanford.dat

  OUTPUT
    PH
    FREE_ION
      O2(aq)
      CH4(aq)
      HCO3-
    TOTAL
      Fe++
      Fe+++
      DOM1
      Tracer2
      Tracer3
    MINERALS
      Fe(OH)3
      Fe(OH)2
    IMMOBILE
      cellulose
      HRimm
  /
END

#=========================== transport constraints ============================
CONSTRAINT initial
  IMMOBILE
    cellulose            5.00e+04     # Much higher cellulose content
    HRimm                1.00e+03     # Higher humified material
  /
  CONCENTRATIONS
    DOM1                2.00d-01 T   # Higher dissolved organic matter
    H+                  6.5 P        # Slightly acidic pH ~6.5
    O2(aq)              1.d-5 T O2(g) # Lower oxygen (anaerobic conditions)
    HCO3-               1.00d-3 T CO2(g) # Higher bicarbonate from decomposition
    Fe+++               1.0d-6 M Fe(OH)3  # Lower iron
    Fe++                1.0d-4 T Fe(OH)2  # Lower iron
    NH4+                5.00d-3 T    # Higher nitrogen from protein breakdown
    Tracer              1.00d-15 T
    Tracer2             1.00d-15 T
    Tracer3             1.00d-15 T
    CH4(aq)             1.00d-4 T    # Some methane from anaerobic decomposition
    Acetate-            1.00d-3 T    # Higher acetate from fermentation
    H2(aq)              1.00d-6 T    # Some hydrogen from fermentation
    Mg++                1.00d-3 T    # Nutrients from biomass
    Ca++                2.00d-3 T    # Higher calcium in biomass
    Na+                 5.00d-4 T    # Lower sodium
    K+                  3.00d-3 T    # Higher potassium (common in biomass)
    Cl-                 1.00d-2 T
  /
  MINERALS
    Fe(OH)3             1.0d-8  1.d2 m^2/m^3    # Much lower iron minerals
    Fe(OH)2             1.0d-6  1.d2 m^2/m^3    # Much lower iron minerals
    Rock(s)             0.05    1.0e2 m^2/m^3   # Much lower mineral content
  /
END

CONSTRAINT atmospheric
  CONCENTRATIONS
    DOM1                1.00d-15 T
    H+                  5.0 P
    O2(aq)              0.2 G O2(g)
    HCO3-               0.01 G CO2(g)
    Fe+++               1.00d-15 M Fe(OH)3
    Fe++                1.00d-15 M Fe(OH)2
    NH4+                1.00d-15 T
    Tracer              1.00d-15 T
    Tracer2             1.00d-15 T
    Tracer3             1.00d-15 T
    CH4(aq)             1.00d-15 T
    Acetate-            1.00d-15 T
    H2(aq)              1.00d-15 T
    Mg++                1.00d-15 T
    Ca++                1.00d-15 T
    Na+                 1.00d-15 T
    K+                  1.00d-15 T
    Cl-                 1.00d-15 T 
  /
  MINERALS
    Fe(OH)3             1.0d-20  1.d2 m^2/m^3
    Fe(OH)2             1.0d-20  1.d2 m^2/m^3
    Rock(s)             0.5  5.0e3 m^2/m^3
  /
END

#=========================== solver options ===================================
NUMERICAL_METHODS TRANSPORT
LINEAR_SOLVER
  SOLVER DIRECT
END

NEWTON_SOLVER
  ATOL 1.d-20
  RTOL 1.d-15
  STOL 1.d-10
  ITOL 1.d-10
END
END

#=========================== discretization ===================================
GRID
  TYPE structured
  ORIGIN 0.d0 0.d0 0.d0
  NXYZ 10 10 10
  DXYZ 
     1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0
     1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0
     1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0 1.0d0
  /
END

PROC 1 1 1

#=========================== fluid properties =================================
FLUID_PROPERTY
  PHASE LIQUID
  DIFFUSION_COEFFICIENT 1.d-7
END

FLUID_PROPERTY
  PHASE gas
  DIFFUSION_COEFFICIENT 2.d-4
END

#=========================== material properties ==============================
MATERIAL_PROPERTY biomass
  ID 1
  POROSITY 0.85d0                    # Much higher porosity for biomass
  SOIL_COMPRESSIBILITY 1.d-05       # More compressible than soil
  SOIL_REFERENCE_PRESSURE 201325.d0
  ROCK_DENSITY 1200.0d0             # Lower density ~1.2 g/cm³ for organic matter
  SPECIFIC_HEAT 1500.0d0            # Higher specific heat for organic material
  THERMAL_CONDUCTIVITY_DRY 0.05d0   # Lower thermal conductivity
  THERMAL_CONDUCTIVITY_WET 0.4d0    # Lower when wet
  CHARACTERISTIC_CURVES biomass_curves
  PERMEABILITY
    PERM_X 1.0d-10                   # Higher permeability due to pore structure
    PERM_Y 1.0d-10
    PERM_Z 1.0d-10
  /
/

CHARACTERISTIC_CURVES biomass_curves
  SATURATION_FUNCTION VAN_GENUCHTEN
    LIQUID_RESIDUAL_SATURATION 0.05d0  # Lower residual saturation
    ALPHA 1.d-3                        # Different pore size distribution
    M 0.8d0                            # Different pore connectivity
    MAX_CAPILLARY_PRESSURE 1.d5
  /
  PERMEABILITY_FUNCTION MUALEM
    PHASE LIQUID
    LIQUID_RESIDUAL_SATURATION 0.05d0
    M 0.8d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_GAS
    PHASE GAS
    LIQUID_RESIDUAL_SATURATION 0.05d0
    GAS_RESIDUAL_SATURATION 1.d-5
    M 0.8d0
  /
END

CHARACTERISTIC_CURVES sf01
  SATURATION_FUNCTION VAN_GENUCHTEN
    LIQUID_RESIDUAL_SATURATION 0.1d0
    ALPHA 1.d-4
    M 0.5d0
    MAX_CAPILLARY_PRESSURE 1.d6
  /
  PERMEABILITY_FUNCTION MUALEM
    PHASE LIQUID
    LIQUID_RESIDUAL_SATURATION 0.1d0
    M 0.5d0
  /
  PERMEABILITY_FUNCTION MUALEM_VG_GAS
    PHASE GAS
    LIQUID_RESIDUAL_SATURATION 0.1d0
    GAS_RESIDUAL_SATURATION 1.d-5
    M 0.5d0
  /
END

#=========================== output options ===================================
OUTPUT
  SCREEN PERIODIC 1000
  PERIODIC TIME 1.d0 d
  FORMAT TECPLOT POINT
  OBSERVATION_FILE
  PERIODIC TIME 1.d0 d
  VARIABLES
    NO_FLOW_VARIABLES
    NO_ENERGY_VARIABLES
    LIQUID_SATURATION
  /
/
END

#=========================== times ============================================
TIME
  FINAL_TIME 100 d
  INITIAL_TIMESTEP_SIZE 1.0d0 h
  MAXIMUM_TIMESTEP_SIZE 12.d0 h
END

#=========================== regions ==========================================
REGION all
  COORDINATES
    0.d0 0.d0 0.d0
    10.d0 10.d0 10.d0
  /
END

REGION top_surface
  FACE TOP
END

REGION bottom_surface
  FACE BOTTOM
END

REGION west_surface
  FACE WEST
END

REGION east_surface
  FACE EAST
END

REGION south_surface
  FACE SOUTH
END

REGION north_surface
  FACE NORTH
END

REGION center_obs
  COORDINATE 5.d0 5.d0 5.d0
END

#=========================== observation points ===============================
OBSERVATION
  REGION center_obs
END

#=========================== transport conditions =============================
FLOW_CONDITION initial
  TYPE
    GAS_PRESSURE dirichlet
    GAS_SATURATION dirichlet
    TEMPERATURE dirichlet
  /
  GAS_PRESSURE 1.01325d5
  GAS_SATURATION 0.3              # Higher gas saturation due to decomposition
  TEMPERATURE 25.d0               # Higher temperature for active decomposition
/

FLOW_CONDITION atmospheric
  TYPE
    GAS_PRESSURE dirichlet
    GAS_SATURATION dirichlet
    TEMPERATURE dirichlet
  /
  GAS_PRESSURE 1.01325d5
  GAS_SATURATION 0.2
  TEMPERATURE 15.d0
/

TRANSPORT_CONDITION initial
  TYPE dirichlet
  CONSTRAINT_LIST
    0.d0 initial
  /
END

TRANSPORT_CONDITION atmospheric
  TYPE dirichlet
  CONSTRAINT_LIST
    0.d0 atmospheric
  /
END

#=========================== condition couplers ===============================
# initial condition
INITIAL_CONDITION
  TRANSPORT_CONDITION initial
  FLOW_CONDITION initial
  REGION all
END

# boundary conditions for atmospheric exchange on all surfaces
BOUNDARY_CONDITION top_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION top_surface
END

BOUNDARY_CONDITION bottom_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION bottom_surface
END

BOUNDARY_CONDITION west_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION west_surface
END

BOUNDARY_CONDITION east_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION east_surface
END

BOUNDARY_CONDITION south_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION south_surface
END

BOUNDARY_CONDITION north_atm
  TRANSPORT_CONDITION atmospheric
  FLOW_CONDITION atmospheric
  REGION north_surface
END

#=========================== stratigraphy couplers ============================
STRATA
  REGION all
  MATERIAL biomass
END

END_SUBSURFACE